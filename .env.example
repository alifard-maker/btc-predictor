# Copy to .env locally or set in Railway → Variables

# Dashboard login (required for production)
APP_PASSWORD=your-password-here
SESSION_SECRET=random-long-secret-optional

# Required for admin endpoints
ADMIN_API_KEY=change-me-to-a-long-random-string

# PostgreSQL — Railway auto-injects when you add a Postgres plugin
# DATABASE_URL=postgresql://...

# Persistent storage mount (attach a Railway Volume at /data)
DATA_DIR=/data

# Exchange
EXCHANGE=coinbaseexchange
SYMBOL=BTC/USD
EXCHANGE_FALLBACKS=kraken,coinbase,bitstamp
PRICE_FEED_LIVE=coinbase

# Scheduler runs automatically in the API process
ENABLE_SCHEDULER=true

# Required to switch any bot from paper → live (dashboard prompts on toggle)
# LIVE_BET_PASSWORD=Ducati1098R!

# Optional: auto-enable paper auto-bet on first boot (empty bot DB only)
# PAPER_BOT_AUTO_ENABLE=btc,eth,slot15

# CORS for a future frontend
CORS_ORIGINS=*

# Kalshi API (optional — public KXBTC15M data works without keys)
# Key ID from Kalshi → Account & security → API Keys
KALSHI_KEY_ID=
# Paste full PEM private key (use \n for newlines on Railway) OR set path locally:
KALSHI_PRIVATE_KEY=
KALSHI_PRIVATE_KEY_PATH=
# KALSHI_PRIVATE_KEY_PASSPHRASE=
# KALSHI_BASE_URL=https://api.elections.kalshi.com/trade-api/v2
# KALSHI_SERIES_TICKER=KXBTC15M
